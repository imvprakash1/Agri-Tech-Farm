# MQTT broker connection URL
MQTT_BROKER=mqtt://localhost:1883

# HTTP server port
PORT=3002

# ── pH Balancing Loop (Node A) ──────────────────────────────
# pH range — values outside trigger dosing after sustained violation
PH_LOW=6.0
PH_HIGH=8.5
# Duration pH must remain out of range before dosing starts (ms) — default: 5 min
PH_VIOLATION_MS=300000
# How long the doser runs per activation (ms) — default: 5 sec
PH_DOSE_MS=5000
# Cooldown after dosing before re-evaluation (ms) — default: 10 min
PH_COOLDOWN_MS=600000

# ── CO2 Purge Loop (Node B) ─────────────────────────────────
# CO2 upper threshold to start purging (ppm)
CO2_HIGH=1000
# CO2 lower threshold to stop purging (ppm)
CO2_LOW=600

# ── Thermal Battery Loop (Node C → Node B) ──────────────────
# Minimum solar output (%) before chilling begins
SOLAR_THRESHOLD=80
# Chilling window — hours (24h format)
CHILL_START_HOUR=12
CHILL_END_HOUR=15
# Circulation window — hours (24h format, wraps past midnight)
CIRCULATE_START_HOUR=20
CIRCULATE_END_HOUR=6

# State machine tick interval (ms) — default: 10 sec
TICK_INTERVAL_MS=10000
