# MQTT broker connection URL
MQTT_BROKER=mqtt://localhost:1883

# HTTP server port
PORT=3001

# Telegram bot credentials (get from @BotFather)
# Leave empty to disable Telegram alerts (alerts still log to console)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alert deduplication cooldown (ms) — default: 15 min
ALERT_COOLDOWN_MS=900000

# Heartbeat check interval (ms) — default: 1 min
HEARTBEAT_INTERVAL_MS=60000

# Node offline timeout (ms) — default: 5 min
NODE_TIMEOUT_MS=300000
